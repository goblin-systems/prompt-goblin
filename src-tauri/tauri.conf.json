{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prompt Goblin",
  "version": "0.1.0",
  "identifier": "com.prompt-goblin",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Prompt Goblin",
        "width": 480,
        "height": 640,
        "resizable": true,
        "center": true,
        "visible": true,
        "decorations": false
      },
      {
        "label": "overlay",
        "title": "",
        "url": "/overlay.html",
        "width": 340,
        "height": 116,
        "resizable": false,
        "decorations": false,
        "shadow": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "center": false,
        "x": 800,
        "y": 40
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "global-shortcut": null,
    "store": null
  }
}
